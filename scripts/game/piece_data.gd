static func get_shape(type: int, rotation: int) -> Array:
	var s = SHAPES.get(type, SHAPES[PIECE_T])
	return s[rotation % 4]

static func get_cells(type: int, rotation: int) -> Array:
	var shape = get_shape(type, rotation)
	var cells = []
	for i in 16:
		if shape[i] == 1:
			cells.append(Vector2i(i % 4, i >> 2))
	return cells

static func get_color(type: int) -> Color:
	return COLORS.get(type, Color.WHITE)

static func get_wall_kicks(type: int, from_rot: int, to_rot: int) -> Array:
	var key = str(from_rot) + ">" + str(to_rot)
	if type == PIECE_I:
		return WALL_KICKS_I.get(key, [[0,0]])
	elif type == PIECE_O:
		return [[0,0]]
	else:
		return WALL_KICKS_JLSTZ.get(key, [[0,0]])

static func get_spawn_position(type: int) -> Vector2i:
	if type == PIECE_O:
		return Vector2i(4, 0)
	return Vector2i(3, 0)
